{
  "name": "snippet-sprint",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "実コードのスニペットを打って学ぶ、Three.js 製プログラミング・タイピングゲーム",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@vercel/analytics": "^2.0.1",
    "three": "0.184.0"
  },
  "devDependencies": {
    "@types/three": "^0.184.0",
    "@vitest/coverage-v8": "^4.1.6",
    "typescript": "6.0.3",
    "vite": "8.1.0",
    "vitest": "^4.1.6"
  }
}
